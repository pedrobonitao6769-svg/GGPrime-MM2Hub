-- Sistema de busca de coins (otimizado)
local function findCoins()
    local coins = {}
    local container = WS:FindFirstChild("CoinContainer")
    
    if container then
        for _, obj in ipairs(container:GetChildren()) do
            if obj:IsA("BasePart") and (obj.Name == "Coin_Server" or obj.Name == "Coin") then
                table.insert(coins, obj)
            end
        end
    else
        -- Fallback (mais eficiente que varrer todos os descendentes)
        for _, obj in ipairs(WS:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name == "Coin_Server" or obj.Name == "Coin") then
                table.insert(coins, obj)
            end
        end
    end
    
    return coins
end

-- Kill All otimizado
local function killAllF()
    if killA then return end
    killA = true
    n("🔪 KILL ALL", "Ativado!", 3)
    
    task.spawn(function()
        while killA do
            task.wait(0.3)
            pcall(function()
                if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
                
                local hrp = plr.Character.HumanoidRootPart
                local hum = plr.Character:FindFirstChild("Humanoid")
                if not hum or hum.Health <= 0 then return end
                
                local knife = plr.Character:FindFirstChild("Knife") or (plr.Backpack and plr.Backpack:FindFirstChild("Knife"))
                
                if S.InstantKillAll then
                    -- Instant Kill All (teleport para o void)
                    for _, p in ipairs(P:GetPlayers()) do
                        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            p.Character.HumanoidRootPart.CFrame = CFrame.new(0, -500, 0)
                        end
                    end
                else
                    -- Kill All normal
                    for _, p in ipairs(P:GetPlayers()) do
                        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local targetHRP = p.Character.HumanoidRootPart
                            local targetHum = p.Character:FindFirstChild("Humanoid")
                                       
                            if targetHum and targetHum.Health > 0 then
                                hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -3)
                                task.wait(0.1)
                                
                                if knife then
                                    knife.Parent = plr.Character
                                    task.wait(0.1)
                                    knife:Activate()
                                    knife.Parent = plr.Backpack
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)
end

local function stopKA()
    killA = false
    n("🔪 KILL ALL", "Desativado", 2)
end

-- Auto Farm otimizado
local function autoFarmF()
    if autoF then return end
    autoF = true
    n("💰 AUTO FARM", "Ativado!", 3)
    
    task.spawn(function()
        while autoF do
            task.wait(0.5)
            pcall(function()
                if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
                
                local hrp = plr.Character.HumanoidRootPart
                local coins = findCoins()
                
                if #coins > 0 then
                    local closest = coins[1]
                    local minDist = (closest.Position - hrp.Position).Magnitude
                    
                    for i = 2, #coins do
                        local c = coins[i]
                        if c and c.Parent then
                            local dist = (c.Position - hrp.Position).Magnitude
                            if dist < minDist then
                                minDist = dist
                                closest = c
                            end
                        end
                    end
                    
                    if closest then
                        hrp.CFrame = CFrame.new(closest.Position + Vector3.new(0, 3, 0))
                        task.wait(0.1)
                        
                        if (closest.Position - hrp.Position).Magnitude < 10 then
                            firetouchinterest(hrp, closest, 0)
                            task.wait(0.1)
                            firetouchinterest(hrp, closest, 1)
                        end
                    end
                end
            end)
        end
    end)
end

local function stopAF()
    autoF = false
    n("💰 AUTO FARM", "Desativado", 2)
end

-- Aim Assist otimizado
local function aimF()
    if aimC then return end
    aimC = true
    n("🎯 AIM ASSIST", "Ativado!", 3)
    
    local connection
    connection = RS.RenderStepped:Connect(function()
        if not S.AimAssist or not aimC then
            connection:Disconnect()
            return
        end
        
        pcall(function()
            if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
            
            local target = xer
            
            if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
                -- Busca alvo mais próximo
                local minDist = math.huge
                local hrp = plr.Character.HumanoidRootPart
                
                for _, p in ipairs(P:GetPlayers()) do
                    if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local targetHRP = p.Character.HumanoidRootPart
                        local targetHum = p.Character:FindFirstChild("Humanoid")
                        
                        if targetHum and targetHum.Health > 0 then
                            local dist = (targetHRP.Position - hrp.Position).Magnitude
                            if dist < 100 and dist < minDist then
                                minDist = dist
                                target = p
                            end
                        end
                    end
                end
            end
            
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = target.Character.HumanoidRootPart.Position
                local current = cam.CFrame
                local lookAt = CFrame.lookAt(current.Position, targetPos)
                cam.CFrame = current:Lerp(lookAt, S.AimAssistForca)
            end
        end)
    end)
end

