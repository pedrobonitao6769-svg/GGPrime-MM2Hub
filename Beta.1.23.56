-- ==================== AIM ASSIST ====================
local function aimF()
    if aimC then return end
    aimC = true
    n("🎯 AIM ASSIST", "Ativado!", 3)
    local connection
    connection = RS.RenderStepped:Connect(function()
        if not S.AimAssist or not aimC then connection:Disconnect(); return end
        pcall(function()
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local target = ass
            if not target or not target.Character then
                for _,p in pairs(P:GetPlayers()) do
                    if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        target = p; break
                    end
                end
            end
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                cam.CFrame = CFrame.new(cam.CFrame.Position, target.Character.HumanoidRootPart.Position)
            end
        end)
    end)
end

local function stopAim()
    aimC = false
    n("🎯 AIM ASSIST", "Desativado", 2)
end

-- ==================== TP TOOL ====================
local function createTPTool()
    if tpToolPart then pcall(function() tpToolPart:Destroy() end) end
    tpToolPart = Instance.new("Part")
    tpToolPart.Name = "TP_TOOL"
    tpToolPart.Size = Vector3.new(2,2,2)
    tpToolPart.BrickColor = BrickColor.new("Bright violet")
    tpToolPart.Material = Enum.Material.Neon
    tpToolPart.Anchored = true
    tpToolPart.CanCollide = false
    tpToolPart.Parent = WS
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "TP_GUI"
    billboard.Size = UDim2.new(0,100,0,50)
    billboard.StudsOffset = Vector3.new(0,3,0)
    billboard.AlwaysOnTop = true
    billboard.Parent = tpToolPart
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.Text = "📍 TP TOOL\n(Clique para teleportar)"
    text.TextColor3 = Color3.new(1,1,1)
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.Parent = billboard
    
    local click = Instance.new("ClickDetector")
    click.Parent = tpToolPart
    click.MaxActivationDistance = 100
    
    click.MouseClick:Connect(function(player)
        if player == plr then
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = tpToolPart.CFrame * CFrame.new(0,3,0)
                n("📍 TP", "Teleportado!", 2)
            end
        end
    end)
    
    task.spawn(function()
        while S.TPTool and tpToolPart do
            task.wait()
            local mouse = plr:GetMouse()
            if mouse then
                local hit = mouse.Target
                if hit then
                    tpToolPart.CFrame = CFrame.new(hit.Position + Vector3.new(0,1,0))
                end
            end
        end
    end)
end

-- ==================== AUTO TP ====================
local function autoTP()
    task.spawn(function()
        while S.TPAuto do
            task.wait(0.3)
            pcall(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local target = xer or ass
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-2)
                end
            end)
        end
    end)
end

-- ==================== REVEAL MURDERER ====================
local function revealMurderer()
    task.spawn(function()
        while S.RevealMurderer do
            task.wait(0.5)
            for _,p in pairs(P:GetPlayers()) do
                if p ~= plr and p.Character then
                    if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                        if not p.Character:FindFirstChild("RevealESP") then
                            local h = Instance.new("Highlight")
                            h.Name = "RevealESP"
                            h.FillColor = Color3.fromRGB(255,0,0)
                            h.FillTransparency = 0.2
                            h.Parent = p.Character
                            n("👁 ASSASSINO", p.Name.." é o assassino!", 3)
                        end
                    end
                end
            end
        end
    end)
end

-- ==================== INSTANT KILL ALL (CORRIGIDO) ====================
local function instantKillAll()
    for _,p in pairs(P:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum then
                hum.Health = 0
            end
            p.Character.HumanoidRootPart.CFrame = CFrame.new(0, -1000, 0)
        end
    end
    n("⚡ INSTANT KILL ALL", "Todos eliminados!", 2)
end

-- ==================== AUTO WIN (CORRIGIDO) ====================
local function autoWin()
    task.spawn(function()
        while S.AutoWin do
            task.wait(0.2)
            pcall(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                local knife = char:FindFirstChild("Knife") or plr.Backpack:FindFirstChild("Knife")
                
                if knife then
                    for _,p in pairs(P:GetPlayers()) do
                        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local hum = p.Character:FindFirstChild("Humanoid")
                            if hum and hum.Health > 0 then
                                hrp.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-2)
                                task.wait(0.05)
                                knife.Parent = char
                                knife:Activate()
                                task.wait(0.05)
                                knife.Parent = plr.Backpack
                                hum.Health = 0
                            end
                        end
                    end
                end
                
                local murderer = ass
                if murderer and murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart") then
                    hrp.CFrame = murderer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-2)
                end
            end)
        end
    end)
end

-- ==================== SPEED BOOST, INFINITE JUMP, NOCLIP ====================
RS.Heartbeat:Connect(function()
    local char = plr.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = S.SpeedBoost and S.SpeedBoostValue or 16
    end
end)

UIS.JumpRequest:Connect(function()
    if S.InfiniteJump then
        local char = plr.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

RS.Stepped:Connect(function()
    if S.NoClip then
        local char = plr.Character
        if char and char:FindFirstChild("Humanoid") then
            for _,v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
end)

-- ==================== FLY ====================
local function startFly()
    if flying then return end
    flying = true
    n("🪽 FLY", "Ativado! W=avançar, S=voltar, A=esquerda, D=direita, Espaço=subir, Ctrl=descer", 3)
    
    local char = plr.Character
    if not char then flying = false; return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then flying = false; return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then flying = false; return end
    
    if bv then bv:Destroy() end
    if bg then bg:Destroy() end
    
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = hrp
    
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bg.CFrame = cam.CFrame
    bg.Parent = hrp
    
    hum.PlatformStand = true
    hum.AutoRotate = false
    
    flyConnection = RS.RenderStepped:Connect(function()
        if not flying or not plr.Character then return end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local moveDir = Vector3.new()
        
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
        
        if UIS:IsKeyDown(Enum.KeyCode.Space) then
            moveDir = moveDir + Vector3.new(0, 1, 0)
        end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
            moveDir = moveDir + Vector3.new(0, -1, 0)
        end
        
        if moveDir.Magnitude > 0 then
            bv.Velocity = moveDir.Unit * 60
        else
            bv.Velocity = Vector3.new()
        end
        
        bg.CFrame = cam.CFrame
    end)
end

local function stopFly()
    flying = false
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    if bv then bv:Destroy(); bv = nil end
    if bg then bg:Destroy(); bg = nil end
    local char = plr.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate = true
        end
    end
    n("🪽 FLY", "Desativado!", 2)
end

-- ==================== HITBOX EXPANDER (CORRIGIDO) ====================
local function expandHitbox()
    for _,p in pairs(P:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local hrp = p.Character.HumanoidRootPart
                hrp.Size = Vector3.new(15, 15, 15)
                hrp.Transparency = 0.3
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = true
                -- Força o servidor a reconhecer a hitbox maior
                local remote = RS:FindFirstChild("HitboxUpdate")
                if remote then
                    remote:FireServer(hrp)
                end
            end)
        end
    end
    n("📦 Hitbox Expander", "Hitboxes expandidas! (15x15x15)", 2)
end

-- ==================== GHOST MODE ====================
local function ghostMode(v)
    ghost = v
    local char = plr.Character
    if char then
        for _,part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = ghost and 0.7 or 0
                part.CanCollide = not ghost
            end
        end
    end
    n("👻 Modo Fantasma", ghost and "Ativado! (70% transparente)" or "Desativado!", 2)
end

-- ==================== SPIN WILL (CORRIGIDO - DANO REAL) ====================
local function startSpin()
    if spinning then return end
    spinning = true
    n("🌀 SPIN WILL", "Ativado! Girando e lançando jogadores...", 3)
    
    spinConnection = RS.RenderStepped:Connect(function()
        if not spinning or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
        
        local hrp = plr.Character.HumanoidRootPart
        local hum = plr.Character:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(800), 0)
        
        local murderer = ass
        if murderer and murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart") then
            hrp.CFrame = murderer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
        end
        
        for _,p in pairs(P:GetPlayers()) do
            if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local targetHrp = p.Character.HumanoidRootPart
                local targetHum = p.Character:FindFirstChild("Humanoid")
                if targetHrp and targetHum then
                    local dir = (targetHrp.Position - hrp.Position).Unit
                    targetHrp.Velocity = dir * 200 + Vector3.new(0, 100, 0)
                    targetHum.Health = targetHum.Health - 75
                end
            end
        end
    end)
end

local function stopSpin()
    spinning = false
    if spinConnection then spinConnection:Disconnect(); spinConnection = nil end
    n("🌀 SPIN WILL", "Desativado!", 2)
end

-- ==================== TP PLAYERS (CORRIGIDO) ====================
local function tpPlayers()
    local char = plr.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    for _,p in pairs(P:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(math.random(-5,5),0,math.random(-5,5))
        end
    end
    n("👥 TP Players", "Jogadores teleportados para você!", 2)
end

-- ==================== CRIAÇÃO DO HUB PRINCIPAL ====================
local function createHub()
    local gui = Instance.new("ScreenGui")
    gui.Name = "GGPrimeHub"
    gui.Parent = plr:WaitForChild("PlayerGui")
    gui.ResetOnSpawn = false

    local open = Instance.new("TextButton")
    open.Parent = gui
    open.Size = UDim2.new(0,60,0,60)
    open.Position = UDim2.new(0,20,0.7,0)
    open.Text = "GG"
    open.BackgroundColor3 = Color3.fromRGB(255,0,0)
    open.TextColor3 = Color3.new(1,1,1)
    open.Font = Enum.Font.GothamBold
    open.TextSize = 18
    open.BorderSizePixel = 0
    Instance.new("UICorner", open).CornerRadius = UDim.new(1,0)

    local main = Instance.new("Frame")
    main.Parent = gui
    main.Size = UDim2.new(0,520,0,380)
    main.Position = UDim2.new(0.5,-260,0.5,-190)
    main.BackgroundColor3 = Color3.fromRGB(20,20,28)
    main.Active = true
    main.Draggable = true
    main.Visible = false
    main.BorderSizePixel = 0
    Instance.new("UICorner", main)

    local top = Instance.new("Frame", main)
    top.Size = UDim2.new(1,0,0,40)
    top.BackgroundColor3 = Color3.fromRGB(255,0,0)
    top.BorderSizePixel = 0
    Instance.new("UICorner", top).CornerRadius = UDim.new(0,8)

    local title = Instance.new("TextLabel", top)
    title.Size = UDim2.new(1,0,1,0)
    title.BackgroundTransparency = 1
    title.Text = "GG PRIME PRO-SCRIPTS (MM2 HUB)"
    title.Font = Enum.Font.GothamBold
    title.TextColor3 = Color3.new(1,1,1)
    title.TextSize = 16

    local close = Instance.new("TextButton", top)
    close.Size = UDim2.new(0,40,1,0)
    close.Position = UDim2.new(1,-40,0,0)
    close.Text = "X"
    close.BackgroundColor3 = Color3.fromRGB(200,0,0)
    close.TextColor3 = Color3.new(1,1,1)
    close.Font = Enum.Font.GothamBold
    close.TextSize = 20
    close.BorderSizePixel = 0
    Instance.new("UICorner", close).CornerRadius = UDim.new(0,8)
    close.MouseButton1Click:Connect(function()
        main.Visible = false
        open.Visible = true
    end)

    open.MouseButton1Click:Connect(function()
        main.Visible = true
        open.Visible = false
    end)

    local side = Instance.new("Frame", main)
    side.Size = UDim2.new(0,150,1,-40)
    side.Position = UDim2.new(0,0,0,40)
    side.BackgroundColor3 = Color3.fromRGB(25,25,35)
    side.BorderSizePixel = 0
    Instance.new("UICorner", side).CornerRadius = UDim.new(0,8)

    local sideLayout = Instance.new("UIListLayout", side)
    sideLayout.Padding = UDim.new(0,10)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local tabs = {}
    local function createTab(n)
        local s = Instance.new("ScrollingFrame")
        s.Parent = main
        s.Size = UDim2.new(1,-170,1,-50)
        s.Position = UDim2.new(0,160,0,45)
        s.BackgroundTransparency = 1
        s.Visible = false
        s.ScrollBarThickness = 4
        s.ScrollBarImageColor3 = Color3.fromRGB(255,0,0)
        s.BorderSizePixel = 0
        s.CanvasSize = UDim2.new(0,0,0,0)
        s.AutomaticCanvasSize = Enum.AutomaticSize.Y
        local layout = Instance.new("UIListLayout", s)
        layout.Padding = UDim.new(0,10)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        tabs[n] = s
        return s
    end

    local function openTab(n)
        for _,v in pairs(tabs) do v.Visible = false end
        tabs[n].Visible = true
    end

    local aTab = createTab("Assassino")
    local xTab = createTab("Xerife")
    local cTab = createTab("Config")
    local eTab = createTab("Extra")
    local opTab = createTab("OP1")
    local fTab = createTab("Funções")
    openTab("Assassino")

    local function sideBtn(t, tab)
        local b = Instance.new("TextButton")
        b.Parent = side
        b.Size = UDim2.new(1,-10,0,40)
        b.Text = t
        b.BackgroundColor3 = Color3.fromRGB(35,35,50)
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.GothamBold
        b.TextSize = 14
        b.BorderSizePixel = 0
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        b.MouseButton1Click:Connect(function() openTab(tab) end)
    end

    sideBtn("🔪 Assassino","Assassino")
    sideBtn("🔫 Xerife","Xerife")
    sideBtn("⚙ Config","Config")
    sideBtn("⭐ Extra","Extra")
    sideBtn("🧪 OP1","OP1")
    sideBtn("🧩 Funções","Funções")

    local function newToggle(p, t, c)
        local s = false
        local b = Instance.new("TextButton")
        b.Parent = p
        b.Size = UDim2.new(1,-10,0,45)
        b.Text = t.." : OFF"
        b.BackgroundColor3 = Color3.fromRGB(35,35,50)
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.GothamBold
        b.TextSize = 14
        b.BorderSizePixel = 0
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        b.MouseButton1Click:Connect(function()
            s = not s
            b.Text = t.." : "..(s and "ON" or "OFF")
            b.BackgroundColor3 = s and Color3.fromRGB(255,0,0) or Color3.fromRGB(35,35,50)
            c(s)
        end)
    end

    local function newBtn(p, t, c)
        local b = Instance.new("TextButton")
        b.Parent = p
        b.Size = UDim2.new(1,-10,0,45)
        b.Text = t
        b.BackgroundColor3 = Color3.fromRGB(35,35,50)
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.GothamBold
        b.TextSize = 14
        b.BorderSizePixel = 0
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        b.MouseButton1Click:Connect(c)
    end

    -- ASSASSINO
    newToggle(aTab, "🔪 Kill All", function(v) S.KillAll=v; if v then killAllF() else stopKA() end end)
    newToggle(aTab, "💰 Auto Farm", function(v) S.AutoFarm=v; if v then autoFarmF() else stopAF() end end)
    newToggle(aTab, "🪙 Auto Pick Coins", function(v) S.AutoPickCoins=v; if v then autoPickCoins() end end)
    newToggle(aTab, "👁 Reveal Murderer", function(v) S.RevealMurderer=v; if v then revealMurderer() end end)
    newBtn(aTab, "⚡ Instant Kill All", function() instantKillAll() end)
    newToggle(aTab, "🏆 Auto Win", function(v) S.AutoWin=v; if v then autoWin() end end)
    newToggle(aTab, "🌀 Spin Will (OP)", function(v) if v then startSpin() else stopSpin() end end)

    -- XERIFE
    newToggle(xTab, "🎯 Aim Assist", function(v) S.AimAssist=v; if v then aimF() else stopAim() end end)
    newToggle(xTab, "🔫 Auto Pick Gun", function(v) S.AutoPickGun=v; if v then autoPickGun() end end)
    newToggle(xTab, "📍 TP Tool", function(v) S.TPTool=v; if v then createTPTool() elseif tpToolPart then tpToolPart:Destroy() end end)
    newToggle(xTab, "🤖 Auto TP", function(v) S.TPAuto=v; if v then autoTP() end end)

    -- CONFIG
    newToggle(cTab, "🔴 ESP Murderer", function(v) S.ESPMurderer=v; espUp() end)
    newToggle(cTab, "🔵 ESP Sheriff", function(v) S.ESPSheriff=v; espUp() end)
    newToggle(cTab, "🟡 ESP Gun Drop", function(v) S.ESPGunDrop=v; espUp() end)
    newToggle(cTab, "👤 ESP Players", function(v) S.ESPPlayers=v; espUp() end)
    newToggle(cTab, "💰 Coin ESP", function(v) S.ESPCoins=v; espUp() end)
    newToggle(cTab, "📏 Tracer/Line", function(v) S.Tracer=v; updateTracer() end)
    newToggle(cTab, "⚡ Speed Boost", function(v) S.SpeedBoost=v end)
    newToggle(cTab, "🦘 Infinite Jump", function(v) S.InfiniteJump=v end)
    newToggle(cTab, "🚪 NoClip", function(v) S.NoClip=v end)
    newBtn(cTab, "💀 Reset Character", function() if plr.Character and plr.Character:FindFirstChild("Humanoid") then plr.Character.Humanoid.Health=0 end end)

    -- EXTRA
    newToggle(eTab, "🔄 Auto Respawn", function(v) S.AutoRespawn=v; autoRespawn() end)
    newToggle(eTab, "🍬 Candy/Event Farm", function(v) S.CandyFarm=v; candyFarm() end)
    newToggle(eTab, "🐢 Farm Sem Ban", function(v) S.SafeFarm=v; safeFarm() end)
    newToggle(eTab, "👀 Spectate", function(v) S.Spectate=v; startSpectate() end)
    newBtn(eTab, "🧘 Sit", function() if plr.Character and plr.Character:FindFirstChild("Humanoid") then plr.Character.Humanoid.Sit = true end end)
    newToggle(eTab, "💀 Show Dead Chat", function(v) S.ShowDeadChat=v; showDeadChat() end)
    newToggle(eTab, "🔇 Mute Radio", function(v) S.MuteRadio=v; muteRadio() end)
    newToggle(eTab, "😀 Emoji Spammer", function(v) S.EmojiSpammer=v; emojiSpammer() end)
    newBtn(eTab, "🔄 Rejoin Server", function() TS:Teleport(game.PlaceId,plr) end)
    newBtn(eTab, "🧍 Teleport Lobby", function() if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then plr.Character.HumanoidRootPart.CFrame = CFrame.new(0,10,0) end end)
    newBtn(eTab, "💰 Farm Coins Instant", function()
        pcall(function()
            if not plr.Character then return end
            local hrp = plr.Character.HumanoidRootPart
            for _,c in pairs(findCoins()) do
                hrp.CFrame = CFrame.new(c.Position + Vector3.new(0,3,0))
                task.wait(0.05)
            end
        end)
    end)
    newBtn(eTab, "👥 TP Players", function() tpPlayers() end)

    -- OP1
    newToggle(opTab, "🔥 Super Speed", function(v) S.SpeedBoost=v; S.SpeedBoostValue=v and 60 or 24 end)
    newToggle(opTab, "👻 Full NoClip", function(v) S.NoClip=v end)
    newToggle(opTab, "🦘 OP Infinite Jump", function(v) S.InfiniteJump=v end)
    newBtn(opTab, "💀 Kill Everyone (Void)", function()
        for _,p in pairs(P:GetPlayers()) do
            if p~=plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum then hum.Health = 0 end
                p.Character.HumanoidRootPart.CFrame = CFrame.new(0,-1000,0)
            end
        end
    end)
    newBtn(opTab, "🧲 Collect All Coins", function()
        pcall(function()
            if not plr.Character then return end
            local hrp = plr.Character.HumanoidRootPart
            for _,c in pairs(findCoins()) do
                hrp.CFrame = CFrame.new(c.Position + Vector3.new(0,3,0))
                task.wait(0.03)
            end
        end)
    end)
    newBtn(opTab, "🚀 TP Random Player", function()
        local players = P:GetPlayers()
        local target = players[math.random(1,#players)]
        if target and target~=plr and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            plr.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3)
        end
    end)

    -- FUNÇÕES
    newToggle(fTab, "🪽 Fly (OP)", function(v) if v then startFly() else stopFly() end end)
    newToggle(fTab, "👻 Ghost Mode (OP)", function(v) ghostMode(v) end)
    newBtn(fTab, "📦 Hitbox Expander (OP)", function() expandHitbox() end)
end

-- ==================== INTRODUÇÃO ANIMADA ====================
local function startIntro()
    local introGui = Instance.new("ScreenGui")
    introGui.Name = "GGIntro"
    introGui.Parent = plr:WaitForChild("PlayerGui")
    introGui.ResetOnSpawn = false
    introGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    introGui.IgnoreGuiInset = true

    local bg = Instance.new("Frame")
    bg.Name = "Background"
    bg.Parent = introGui
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BackgroundTransparency = 1

    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Parent = introGui
    container.Size = UDim2.new(0,400,0,200)
    container.Position = UDim2.new(0.5,-200,0.5,-100)
    container.BackgroundTransparency = 1

    local logo = Instance.new("TextLabel")
    logo.Name = "Logo"
    logo.Parent = container
    logo.Size = UDim2.new(1,0,0,80)
    logo.Position = UDim2.new(0,0,0,20)
    logo.BackgroundTransparency = 1
    logo.Text = "GG PRIME"
    logo.TextColor3 = Color3.fromRGB(255,0,0)
    logo.TextScaled = true
    logo.Font = Enum.Font.GothamBlack
    logo.TextStrokeTransparency = 0.5
    logo.TextStrokeColor3 = Color3.fromRGB(255,255,255)

    local glow = Instance.new("TextLabel")
    glow.Name = "Glow"
    glow.Parent = container
    glow.Size = UDim2.new(1,0,0,80)
    glow.Position = UDim2.new(0,0,0,20)
    glow.BackgroundTransparency = 1
    glow.Text = "GG PRIME"
    glow.TextColor3 = Color3.fromRGB(255,100,100)
    glow.TextScaled = true
    glow.Font = Enum.Font.GothamBlack
    glow.TextTransparency = 0.8
    glow.ZIndex = 0

    local subtitle = Instance.new("TextLabel")
    subtitle.Name = "Subtitle"
    subtitle.Parent = container
    subtitle.Size = UDim2.new(1,0,0,40)
    subtitle.Position = UDim2.new(0,0,0,110)
    subtitle.BackgroundTransparency = 1
    subtitle.Text = "MM2 HUB"
    subtitle.TextColor3 = Color3.fromRGB(255,255,255)
    subtitle.TextScaled = true
    subtitle.Font = Enum.Font.GothamBold
    subtitle.TextTransparency = 1

    local loadingBg = Instance.new("Frame")
    loadingBg.Name = "LoadingBg"
    loadingBg.Parent = introGui
    loadingBg.Size = UDim2.new(0,300,0,4)
    loadingBg.Position = UDim2.new(0.5,-150,0.8,0)
    loadingBg.BackgroundColor3 = Color3.fromRGB(50,50,50)
    loadingBg.BorderSizePixel = 0

    local loadingBar = Instance.new("Frame")
    loadingBar.Name = "LoadingBar"
    loadingBar.Parent = introGui
    loadingBar.Size = UDim2.new(0,0,0,4)
    loadingBar.Position = UDim2.new(0.5,-150,0.8,0)
    loadingBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
    loadingBar.BorderSizePixel = 0

    local loadingText = Instance.new("TextLabel")
    loadingText.Name = "LoadingText"
    loadingText.Parent = introGui
    loadingText.Size = UDim2.new(0,300,0,20)
    loadingText.Position = UDim2.new(0.5,-150,0.78,0)
    loadingText.BackgroundTransparency = 1
    loadingText.Text = "CARREGANDO..."
    loadingText.TextColor3 = Color3.fromRGB(200,200,200)
    loadingText.TextSize = 12
    loadingText.Font = Enum.Font.GothamBold
    loadingText.TextXAlignment = Enum.TextXAlignment.Center

    local tweenInfoFade = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    local tweenInfoPulse = TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    local tweenInfoZoom = TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    local bgFade = TweenService:Create(bg, tweenInfoFade, {BackgroundTransparency = 0})
    bgFade:Play()

    logo.Size = UDim2.new(0,0,0,0)
    logo.Position = UDim2.new(0.5,0,0.5,0)
    local logoZoom = TweenService:Create(logo, tweenInfoZoom, {Size = UDim2.new(1,0,0,80), Position = UDim2.new(0,0,0,20)})
    logoZoom:Play()

    task.wait(0.3)
    local logoPulse = TweenService:Create(logo, tweenInfoPulse, {TextColor3 = Color3.fromRGB(255,50,50)})
    local glowPulse = TweenService:Create(glow, tweenInfoPulse, {TextTransparency = 0.6})
    logoPulse:Play()
    glowPulse:Play()

    task.wait(0.5)
    local subFade = TweenService:Create(subtitle, tweenInfoFade, {TextTransparency = 0})
    subFade:Play()

    local loadingTween = TweenService:Create(loadingBar, TweenInfo.new(2, Enum.EasingStyle.Linear), {Size = UDim2.new(1,0,0,4)})
    loadingTween:Play()

    for i = 0, 100, 2 do
        loadingText.Text = "CARREGANDO... "..i.."%"
        task.wait(0.02)
    end

    task.wait(0.3)

    local bgFadeOut = TweenService:Create(bg, tweenInfoFade, {BackgroundTransparency = 1})
    local containerFade = TweenService:Create(container, tweenInfoFade, {BackgroundTransparency = 1})
    local loadingFade = TweenService:Create(loadingBg, tweenInfoFade, {BackgroundTransparency = 1})
    local loadingBarFade = TweenService:Create(loadingBar, tweenInfoFade, {BackgroundTransparency = 1})
    local loadingTextFade = TweenService:Create(loadingText, tweenInfoFade, {TextTransparency = 1})
    
    bgFadeOut:Play()
    containerFade:Play()
    loadingFade:Play()
    loadingBarFade:Play()
    loadingTextFade:Play()

    task.wait(0.5)
    introGui:Destroy()
    
    createHub()
end

-- Iniciar introdução
task.spawn(startIntro)

n("🚀 GG PRIME", "MM2 Hub carregado com sucesso!", 3)
