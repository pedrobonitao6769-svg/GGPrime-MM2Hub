-- ==================== FIND COINS ====================
local function findCoins()
    local c = {}
    for _,v in pairs(WS:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "Coin_Server" or v.Name == "Coin") then
            table.insert(c, v)
        end
    end
    return c
end

-- ==================== AUTO PICK COINS ====================
local function autoPickCoins()
    task.spawn(function()
        while S.AutoPickCoins do
            task.wait(0.2)
            pcall(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                for _,coin in pairs(findCoins()) do
                    if coin and coin.Parent then
                        hrp.CFrame = CFrame.new(coin.Position + Vector3.new(0,2,0))
                        task.wait(0.05)
                        firetouchinterest(hrp, coin, 0)
                        task.wait(0.05)
                        firetouchinterest(hrp, coin, 1)
                    end
                end
            end)
        end
    end)
end

-- ==================== AUTO PICK GUN ====================
local function autoPickGun()
    task.spawn(function()
        while S.AutoPickGun do
            task.wait(0.2)
            pcall(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                for _,v in pairs(WS:GetDescendants()) do
                    if v:IsA("Tool") and v.Name == "Gun" and v.Handle then
                        hrp.CFrame = CFrame.new(v.Handle.Position + Vector3.new(0,2,0))
                        task.wait(0.05)
                        firetouchinterest(hrp, v.Handle, 0)
                        task.wait(0.05)
                        firetouchinterest(hrp, v.Handle, 1)
                        break
                    end
                end
            end)
        end
    end)
end

-- ==================== KILL ALL (CORRIGIDO - FORTE) ====================
local function killAllF()
    if killA then return end
    killA = true
    n("🔪 KILL ALL", "Ativado!", 3)
    task.spawn(function()
        while killA do
            task.wait(0.1)
            pcall(function()
                local char = plr.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                local knife = char:FindFirstChild("Knife") or plr.Backpack:FindFirstChild("Knife")
                if not knife then return end
                
                for _,p in pairs(P:GetPlayers()) do
                    if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local targetHrp = p.Character.HumanoidRootPart
                        local targetHum = p.Character:FindFirstChild("Humanoid")
                        if targetHum and targetHum.Health > 0 then
                            hrp.CFrame = targetHrp.CFrame * CFrame.new(0,0,-2)
                            task.wait(0.05)
                            knife.Parent = char
                            knife:Activate()
                            task.wait(0.05)
                            knife.Parent = plr.Backpack
                            targetHum.Health = 0
                        end
                    end
                end
            end)
        end
    end)
end

local function stopKA()
    killA = false
    n("🔪 KILL ALL", "Desativado", 2)
end

