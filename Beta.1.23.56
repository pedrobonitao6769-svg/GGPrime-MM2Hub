    Tracer = false, AimAssist = false, AimAssistForca = 0.6,
    AutoFarm = false, KillAll = false, SpeedBoost = false, SpeedBoostValue = 24,
    InfiniteJump = false, NoClip = false, AutoPickGun = false, AutoPickCoins = false,
