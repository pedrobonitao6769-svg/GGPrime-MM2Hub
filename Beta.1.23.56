-- Remove GUIs antigas
pcall(function()
    for _,v in pairs(CG:GetChildren()) do
        if v.Name == "GGPrimeHub" or v.Name == "MM2HubUI" or v.Name == "GGIntro" then v:Destroy() end
    end
end)

-- Notificações
local function n(t,d,s)
    if S.Notificacoes then
        pcall(function()
            SG:SetCore("SendNotification", {Title=tostring(t), Text=tostring(d), Duration=s or 3})
        end)
    end
end

-- ==================== FUNÇÕES DO HUB ====================
local function roles()
    local a = nil
    local x = nil
    for _,p in pairs(P:GetPlayers()) do
        if p ~= plr then
            local char = p.Character
            if char then
                if char:FindFirstChild("Knife") or (p.Backpack and p.Backpack:FindFirstChild("Knife")) then
                    a = p
                elseif char:FindFirstChild("Gun") or (p.Backpack and p.Backpack:FindFirstChild("Gun")) then
                    x = p
                end
            end
        end
    end
    ass = a or ass
    xer = x or xer
    return ass, xer
end

task.spawn(function()
    while true do
        task.wait(0.5)
        pcall(roles)
    end
end)

-- ==================== ESP ====================
local function espUp()
    for _,o in pairs(espO) do pcall(function() o:Destroy() end) end
    espO = {}
    local a,x = roles()
    
    if S.ESPMurderer and a and a.Character then
        pcall(function()
            local h = Instance.new("Highlight")
            h.Name = "ESP_Murderer"
            h.Parent = a.Character
            h.FillTransparency = 0.2
            h.OutlineTransparency = 0
            h.FillColor = Color3.fromRGB(255,0,0)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            table.insert(espO, h)
        end)
    end
    
    if S.ESPSheriff and x and x.Character then
        pcall(function()
            local h = Instance.new("Highlight")
            h.Name = "ESP_Sheriff"
            h.Parent = x.Character
            h.FillTransparency = 0.2
            h.OutlineTransparency = 0
            h.FillColor = Color3.fromRGB(0,100,255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            table.insert(espO, h)
        end)
    end
    
    if S.ESPPlayers then
        for _,p in pairs(P:GetPlayers()) do
            if p ~= plr and p.Character and p ~= a and p ~= x then
                pcall(function()
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_Player"
                    h.Parent = p.Character
                    h.FillTransparency = 0.2
                    h.OutlineTransparency = 0
                    h.FillColor = Color3.fromRGB(0,255,0)
                    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    table.insert(espO, h)
                end)
            end
        end
    end
    
    if S.ESPGunDrop then
        for _,v in pairs(WS:GetDescendants()) do
            if (v:IsA("Tool") and v.Name == "Gun") or (v:IsA("BasePart") and string.find(v.Name:lower(), "gun")) then
                pcall(function()
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_Gun"
                    h.Parent = v
                    h.FillTransparency = 0.1
                    h.OutlineTransparency = 0
                    h.FillColor = Color3.fromRGB(255,255,0)
                    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    table.insert(espO, h)
                end)
            end
        end
    end
    
    if S.ESPCoins then
        for _,v in pairs(WS:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name == "Coin_Server" or v.Name == "Coin") then
                pcall(function()
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_Coin"
                    h.Parent = v
                    h.FillTransparency = 0.1
                    h.OutlineTransparency = 0
                    h.FillColor = Color3.fromRGB(255,215,0)
                    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    table.insert(espO, h)
                end)
            end
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if S.ESPMurderer or S.ESPSheriff or S.ESPPlayers or S.ESPGunDrop or S.ESPCoins then
            pcall(espUp)
        end
    end
end)

-- ==================== TRACER/LINE (CORRIGIDO) ====================
local function updateTracer()
    for _,p in pairs(tracerParts) do pcall(function() p:Destroy() end) end
    tracerParts = {}
    if not S.Tracer then return end
    local target = ass or xer
    if not target or not target.Character then return end
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
    if hrp and tHrp then
        local line = Instance.new("Part")
        line.Size = Vector3.new(0.2,0.2,(hrp.Position - tHrp.Position).Magnitude)
        line.CFrame = CFrame.lookAt(hrp.Position, tHrp.Position) * CFrame.new(0,0,-line.Size.Z/2)
        line.BrickColor = BrickColor.new("Bright red")
        line.Material = Enum.Material.Neon
        line.Anchored = true
        line.CanCollide = false
        line.Parent = WS
        table.insert(tracerParts, line)
        task.spawn(function()
            while S.Tracer and line and line.Parent do
                task.wait(0.1)
                local newChar = plr.Character
                if newChar and target.Character then
                    local newHrp = newChar:FindFirstChild("HumanoidRootPart")
                    local newTHrp = target.Character:FindFirstChild("HumanoidRootPart")
                    if newHrp and newTHrp then
                        local newDist = (newHrp.Position - newTHrp.Position).Magnitude
                        line.Size = Vector3.new(0.2,0.2,newDist)
                        line.CFrame = CFrame.lookAt(newHrp.Position, newTHrp.Position) * CFrame.new(0,0,-newDist/2)
                    else
                        break
                    end
                else
                    break
                end
            end
            pcall(function() line:Destroy() end)
        end)
    end
end

task.spawn(function()
    while true do
        task.wait(0.3)
        if S.Tracer then pcall(updateTracer) else for _,p in pairs(tracerParts) do pcall(function() p:Destroy() end) end end
    end
end)

-- ==================== AUTO RESPAWN (CORRIGIDO) ====================
local function autoRespawn()
    if autoRespawnConnection then autoRespawnConnection:Disconnect() end
    if not S.AutoRespawn then return end
    autoRespawnConnection = RS.Stepped:Connect(function()
        local char = plr.Character
        if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health <= 0 then
            task.wait(0.5)
            local respawnBtn = SG:FindFirstChild("RespawnButton")
            if respawnBtn and respawnBtn:IsA("TextButton") then
                respawnBtn:Click()
            end
        end
    end)
end

-- ==================== CANDY/EVENT FARM (CORRIGIDO) ====================
local function candyFarm()
    if candyConnection then candyConnection:Disconnect() end
    if not S.CandyFarm then return end
    candyConnection = RS.Stepped:Connect(function()
        pcall(function()
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            for _,v in pairs(WS:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name:lower():find("candy") or v.Name:lower():find("present") or v.Name:lower():find("egg")) then
                    char.HumanoidRootPart.CFrame = CFrame.new(v.Position + Vector3.new(0,2,0))
                    firetouchinterest(char.HumanoidRootPart, v, 0)
                    firetouchinterest(char.HumanoidRootPart, v, 1)
                end
            end
        end)
    end)
end

-- ==================== SAFE FARM (CORRIGIDO) ====================
local function safeFarm()
    if safeFarmConnection then safeFarmConnection:Disconnect() end
    if not S.SafeFarm then return end
    safeFarmConnection = RS.Stepped:Connect(function()
        pcall(function()
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            for _,v in pairs(WS:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name == "Coin_Server" or v.Name == "Coin") then
                    char.HumanoidRootPart.CFrame = CFrame.new(v.Position + Vector3.new(0,2,0))
                    task.wait(0.1)
                    firetouchinterest(char.HumanoidRootPart, v, 0)
                    firetouchinterest(char.HumanoidRootPart, v, 1)
                end
            end
        end)
    end)
end

-- ==================== SPECTATE (CORRIGIDO) ====================
local function startSpectate()
    if spectateConnection then spectateConnection:Disconnect() end
    if not S.Spectate then 
        workspace.CurrentCamera.CameraSubject = plr.Character
        return 
    end
    local players = P:GetPlayers()
    for _,p in pairs(players) do
        if p ~= plr then
            spectateTarget = p
            break
        end
    end
    if spectateTarget then
        spectateConnection = RS.RenderStepped:Connect(function()
            if not S.Spectate or not spectateTarget or not spectateTarget.Character then
                workspace.CurrentCamera.CameraSubject = plr.Character
                return
            end
            workspace.CurrentCamera.CameraSubject = spectateTarget.Character
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        end)
    end
end

-- ==================== SHOW DEAD CHAT (CORRIGIDO) ====================
local function showDeadChat()
    if deadChatConnection then deadChatConnection:Disconnect() end
    if not S.ShowDeadChat then return end
    deadChatConnection = RS.Stepped:Connect(function()
        for _,p in pairs(P:GetPlayers()) do
            if p ~= plr and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health <= 0 then
                SG:SetCore("ChatMakeSystemMessage", {Text = "💀 "..p.Name.." está morto!", Color = Color3.fromRGB(150,0,0)})
            end
        end
    end)
end

-- ==================== MUTE RADIO (CORRIGIDO) ====================
local function muteRadio()
    if muteRadioConnection then muteRadioConnection:Disconnect() end
    if not S.MuteRadio then 
        for _,v in pairs(WS:GetDescendants()) do
            if v:IsA("Sound") and v.Name:lower():find("radio") then
                v.Volume = 1
            end
        end
        return 
    end
    muteRadioConnection = RS.Stepped:Connect(function()
        for _,v in pairs(WS:GetDescendants()) do
            if v:IsA("Sound") and v.Name:lower():find("radio") then
                v.Volume = 0
            end
        end
    end)
end

